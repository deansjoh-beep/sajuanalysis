rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: blogPosts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - content: string (required, 1-10000 chars)
    //   - category: string (required, 1-50 chars)
    //   - date: string (required, YYYY-MM-DD)
    //   - createdAt: timestamp (required)
    //   - authorUid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "dean.uitrading@gmail.com" || 
              request.auth.token.email == "dean.sj.oh@gmail.com");
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'date', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.createdAt is timestamp &&
             data.authorUid is string && data.authorUid == request.auth.uid &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 500));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /blogPosts/{postId} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can create, update, or delete
      allow create: if isAdmin() && isValidBlogPost(request.resource.data);
      allow update: if isAdmin() && isValidBlogPost(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
