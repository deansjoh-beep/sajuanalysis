# =====================================================================
# sajuanalysis 환경변수 — Phase 0 감사 기준 (2026-07-03)
# =====================================================================
# 실제 코드 참조 위치는 `docs/audit/inventory.md`와 각 파일의 process.env.* 참조.
# 로컬 개발 시 이 파일을 .env.local로 복사 후 값을 채우세요.

# ---------------------------------------------------------------------
# 1) LLM (현행: Google Gemini via @google/genai)
# ---------------------------------------------------------------------
# 서버 측(server.ts, api/*): process.env.GEMINI_API_KEY 우선
# 프론트 측(build 시 주입): process.env.VITE_GEMINI_API_KEY
# ⚠️ Phase 1에서 Anthropic 이관 여부 결정 시 ANTHROPIC_API_KEY 신설 예정 (IMPLEMENTATION_PLAN.md 전제)
GEMINI_API_KEY=""
VITE_GEMINI_API_KEY=""

# ---------------------------------------------------------------------
# 2) Firebase Admin SDK — Firestore/Storage 서버 접근
# ---------------------------------------------------------------------
# 아래 3가지 중 하나로 인증:
#   (a) 프로젝트 루트에 service-account.json 파일 배치 (dev 권장)
#   (b) FIREBASE_SERVICE_ACCOUNT_JSON 에 JSON 전문(전체 문자열) 주입
#   (c) FIREBASE_SERVICE_ACCOUNT_BASE 에 base64 인코딩된 JSON 주입 (Vercel 권장)
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_SERVICE_ACCOUNT_BASE=""

# 개별 필드 대체 (위 3방법이 모두 없을 때 폴백)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firestore 다중 DB — 현행 저장소 ID (server.ts:55 참조)
FIREBASE_DATABASE_ID="ai-studio-fbfb1881-9f6e-4c3b-9700-cb6640ef2eb9"

# Storage 버킷 (없으면 project_id 기반으로 자동 탐색)
FIREBASE_STORAGE_BUCKET=""
FIREBASE_STORAGE_LOCATION=""
REPORTS_STORAGE_BUCKET=""

# ---------------------------------------------------------------------
# 3) 이메일 (Resend)
# ---------------------------------------------------------------------
RESEND_API_KEY=""
VITE_RESEND_API_KEY=""
FROM_EMAIL="noreply@example.com"
VITE_FROM_EMAIL="noreply@example.com"

# ---------------------------------------------------------------------
# 4) PDF 생성 (Puppeteer)
# ---------------------------------------------------------------------
# 로컬 Chrome 경로 (없으면 기본 경로 자동 탐색: server.ts:133~135 참조)
CHROME_PATH=""
# Vercel Functions용 chromium-min 바이너리 URL
CHROMIUM_BINARY_URL=""
# PDF 생성 API 토큰(옵션) — 설정 시 x-pdf-token 헤더 필수
PDF_API_TOKEN=""

# ---------------------------------------------------------------------
# 5) Phase 2 신설 예정 (현재 미사용, 자리 마련만)
# ---------------------------------------------------------------------
# 결제 (토스페이먼츠) — ⛔ OWNER 가맹 승인 후 발급
# 클라이언트 키는 publishable — 브라우저 위젯 초기화용이라 번들에 포함된다(Vite VITE_ 접두사).
# Vercel 빌드 환경변수에도 VITE_TOSS_CLIENT_KEY를 설정해야 프로덕션 결제창이 뜬다. 미설정 시 "결제 준비 중"으로 degrade.
VITE_TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
# 데이터베이스 (Postgres — Neon/Supabase/Vercel Postgres 등 호스팅 중립, D-0-2)
#   Phase 2-1 데이터 계층(db/schema.ts: codes·orders·reports)이 사용.
#   서버리스에서는 반드시 "pooled" 연결 문자열을 넣을 것.
#   미설정 시: 로컬 개발은 PGlite(.pglite/ 파일)로 폴백, 프로덕션 API는 503.
#   호스팅 결정(⛔ OWNER) 후 마이그레이션 적용: npx drizzle-kit migrate
DATABASE_URL=""
POSTGRES_URL=""
# 관리자 접근 토큰 (Phase 2 관리자 화면용)
ADMIN_ACCESS_TOKEN=""
# Anthropic Claude 이관 시
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------
# 6) 시스템
# ---------------------------------------------------------------------
NODE_ENV="development"
# APP_URL (Vercel에서 자동 주입되지만 로컬에서 명시 필요할 수 있음)
APP_URL="http://localhost:3000"
# KASI (한국천문연구원) API — Phase 1 만세력 검증용, 확보 결정 후 활성
KASI_API_KEY=""

# ── 카카오 로그인 (선택) ─────────────────────────────────────────────
# 카카오 로그인은 JS SDK v2 의 authorize(리다이렉트+code) 방식을 사용한다.
#   브라우저가 카카오 인증 페이지로 이동 → 동의 후 redirect_uri 로 ?code= 가 붙어 복귀
#   → 서버(/api/member)가 code 를 access_token 으로 교환 → Firebase 커스텀 토큰 발급.
#
# VITE_KAKAO_JS_KEY: Kakao Developers 앱의 "JavaScript 키" (브라우저 노출 OK, 빌드 시 주입).
#   설정하면 로그인 모달에 카카오 로그인이 활성화된다. 미설정 시 "준비 중"으로 표시.
VITE_KAKAO_JS_KEY=""
# KAKAO_REST_API_KEY: Kakao Developers 앱의 "REST API 키" (서버 전용, 절대 노출 금지).
#   서버에서 인가 코드를 access_token 으로 교환할 때 client_id 로 사용된다.
KAKAO_REST_API_KEY=""
# Kakao Developers 콘솔 설정:
#   - [앱 키]: JavaScript 키 / REST API 키 복사
#   - [카카오 로그인] 활성화 ON
#   - [카카오 로그인 > Redirect URI] 에 정확히 등록:
#       https://sajuanalysis.vercel.app/   (운영, 끝의 / 포함)
#       http://localhost:3000/             (로컬 개발)
#   - [플랫폼 > Web > 사이트 도메인] 에 https://sajuanalysis.vercel.app 등록
#   - [동의항목]: 닉네임/프로필사진(profile_nickname, profile_image), 카카오계정 이메일(account_email)
#   Firebase 커스텀 토큰 발급을 위해 service-account.json (Admin SDK) 도 필요하다.

# ── 오늘의 운세 배치(cron) ───────────────────────────────────────────
# CRON_SECRET: 설정하면 /api/cron/daily-fortune 호출 시
#   Authorization: Bearer <CRON_SECRET> 일치를 요구한다.
#   Vercel Cron 은 이 값을 자동으로 Authorization 헤더에 실어 호출하므로,
#   프로덕션에서는 반드시 설정해 외부 호출을 차단하는 것을 권장한다.
CRON_SECRET=""

# ── 푸시 알림 (FCM 웹 푸시, 선택) ────────────────────────────────────
# VITE_FIREBASE_VAPID_KEY: 웹 푸시 인증서 공개키(브라우저 노출 OK).
#   설정하면 오늘의 운세 페이지에 "매일 아침 알림" 토글이 활성화된다.
#   Firebase 콘솔 > 프로젝트 설정 > 클라우드 메시징 > 웹 구성 >
#   웹 푸시 인증서(Web Push certificates)에서 키 페어 생성 후 공개키를 입력.
#   발송에는 service-account.json(Admin SDK) 이 필요하며, cron 이 매일 발송한다.
VITE_FIREBASE_VAPID_KEY=""
