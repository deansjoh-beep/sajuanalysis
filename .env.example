# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# KASI_API_KEY: Required for Korea Astronomy and Space Science Institute API calls.
KASI_API_KEY=""

# ── 카카오 로그인 (선택) ─────────────────────────────────────────────
# VITE_KAKAO_JS_KEY: Kakao Developers 앱의 JavaScript 키 (브라우저 노출 OK).
#   설정하면 로그인 모달에 카카오 로그인이 활성화된다. 미설정 시 "준비 중"으로 표시.
#   Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
#   추가로 [카카오 로그인] 활성화 + Redirect/사이트 도메인 등록 필요.
VITE_KAKAO_JS_KEY=""
# 서버 측 카카오 검증은 클라이언트 access_token 을 /api/auth/kakao 에서
# kapi.kakao.com 로 검증하므로 별도 REST 키가 필요 없다.
# 단, Firebase 커스텀 토큰 발급을 위해 service-account.json (Admin SDK) 이 필요하다.
