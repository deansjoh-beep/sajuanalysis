# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# KASI_API_KEY: Required for Korea Astronomy and Space Science Institute API calls.
KASI_API_KEY=""

# ── 카카오 로그인 (선택) ─────────────────────────────────────────────
# VITE_KAKAO_JS_KEY: Kakao Developers 앱의 JavaScript 키 (브라우저 노출 OK).
#   설정하면 로그인 모달에 카카오 로그인이 활성화된다. 미설정 시 "준비 중"으로 표시.
#   Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
#   추가로 [카카오 로그인] 활성화 + Redirect/사이트 도메인 등록 필요.
VITE_KAKAO_JS_KEY=""
# 서버 측 카카오 검증은 클라이언트 access_token 을 /api/auth/kakao 에서
# kapi.kakao.com 로 검증하므로 별도 REST 키가 필요 없다.
# 단, Firebase 커스텀 토큰 발급을 위해 service-account.json (Admin SDK) 이 필요하다.

# ── 오늘의 운세 배치(cron) ───────────────────────────────────────────
# CRON_SECRET: 설정하면 /api/cron/daily-fortune 호출 시
#   Authorization: Bearer <CRON_SECRET> 일치를 요구한다.
#   Vercel Cron 은 이 값을 자동으로 Authorization 헤더에 실어 호출하므로,
#   프로덕션에서는 반드시 설정해 외부 호출을 차단하는 것을 권장한다.
CRON_SECRET=""

# ── 푸시 알림 (FCM 웹 푸시, 선택) ────────────────────────────────────
# VITE_FIREBASE_VAPID_KEY: 웹 푸시 인증서 공개키(브라우저 노출 OK).
#   설정하면 오늘의 운세 페이지에 "매일 아침 알림" 토글이 활성화된다.
#   Firebase 콘솔 > 프로젝트 설정 > 클라우드 메시징 > 웹 구성 >
#   웹 푸시 인증서(Web Push certificates)에서 키 페어 생성 후 공개키를 입력.
#   발송에는 service-account.json(Admin SDK) 이 필요하며, cron 이 매일 발송한다.
VITE_FIREBASE_VAPID_KEY=""
